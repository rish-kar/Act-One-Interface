{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      { "source": "/terms{,/**}", "destination": "/terms/index.html" },
      { "source": "/privacy{,/**}", "destination": "/privacy/index.html" },
      { "source": "/refund{,/**}", "destination": "/refund/index.html" },
      { "source": "/return-policy{,/**}", "destination": "/return-policy/index.html" },
      { "source": "/shipping-policy{,/**}", "destination": "/shipping-policy/index.html" },
      { "source": "**", "destination": "/index.html" }
    ]
  }
}